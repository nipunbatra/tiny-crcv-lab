{
  "name": "tiny-crcv-lab",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "prepare:data": "node scripts/prepare_web_data.mjs",
    "predev": "npm run prepare:data",
    "dev": "vite",
